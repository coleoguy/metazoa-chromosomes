lwd = my_lwd,
outline = FALSE,
ftype = "off",
legend = FALSE)
# --- PLOT 2: LEGEND ---
# We create a new, empty plot with fixed coordinates (0 to 1)
# This ensures the legend is ALWAYS in the same spot relative to the page
par(mar = c(0, 0, 0, 0)) # Margins to push it up slightly from bottom edge
plot(0, type = "n", axes = FALSE, xlim = c(0, 1), ylim = c(0, 1), xlab = "", ylab = "")
# Draw the bar exactly in the center (x = 0.5)
add.color.bar(leg = 0.5,           # Width of bar (0.5 means 50% of page width)
cols = obj$cols,
title = "Haploid Number",
lims = obj$lims,
digits = 1,          # Clean rounding
prompt = FALSE,
x = 0,            # Start at 0.25 so it ends at 0.75 (Centered)
y = 0.5,             # Vertical center of the legend strip
lwd = 10,            # Nice thick bar
fsize = .8,         # Readable font
subtitle = "")
# 3. CREATE MAP OBJECT
# Using res=500 and n=1000 for maximum smoothness
obj <- contMap(tr_clean, vals, plot = FALSE, res = 100)
# 1. ROBUST LOAD
name <- tools::file_path_sans_ext(basename(f))
tr   <- tryCatch(read.nexus(f), error = function(e) read.tree(f))
if (inherits(tr, "multiPhylo")) tr <- tr[[1]]
# 2. MATCH DATA
csv_path <- file.path(chrom_dir, paste0(name, ".csv"))
if (!file.exists(csv_path)) next
dat  <- read.csv(csv_path)
# Filter NAs strictly
dat  <- dat[!is.na(dat$haploid), ]
keep <- intersect(tr$tip.label, dat$species)
if (length(keep) < 3) next
tr_clean <- keep.tip(tr, keep)
tr_clean$edge.length[tr_clean$edge.length <= 0] <- 1e-6
vals <- setNames(dat$haploid[match(keep, dat$species)], keep)
# 3. CREATE MAP OBJECT
# Using res=500 and n=1000 for maximum smoothness
obj <- contMap(tr_clean, vals, plot = FALSE, res = 100)
obj <- setMap(obj, viridis(100, direction = -1))
# 4. DYNAMIC LINE WIDTH
# Logic: Never go below 1.5px (prevents dashed lines).
# Scale up for small trees so they don't look spindly.
my_lwd <- max(1.5, 600 / length(keep))
# 5. RENDER
message(paste("Rendering:", name))
# --- THE LAYOUT FIX ---
# We divide the plot into 2 rows.
# Row 1 (Height 0.9) = The Tree
# Row 2 (Height 0.1) = The Legend
layout(matrix(c(1, 2), nrow = 2), heights = c(0.9, 0.1))
# --- PLOT 1: TREE ---
par(mar = c(0, 0, 0, 0)) # No margins for tree to maximize space
plot(obj,
type = "fan",
lwd = my_lwd,
outline = FALSE,
ftype = "off",
legend = FALSE)
# 4. DYNAMIC LINE WIDTH
# Logic: Never go below 1.5px (prevents dashed lines).
# Scale up for small trees so they don't look spindly.
my_lwd <- max(1, 600 / length(keep))
# 5. RENDER
message(paste("Rendering:", name))
