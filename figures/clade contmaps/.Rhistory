library(phytools)
library(viridisLite)
# --- CONFIGURATION ---
tree_dir  <- "../../data/trees"
chrom_dir <- "../../data/chrome"
out_res   <- 300
files <- list.files(tree_dir, pattern = "\\.(tre|nex|newick|nexus)$", full.names = TRUE)
# --- MAIN LOOP ---
for (f in files) {
# 1. LOAD
name <- tools::file_path_sans_ext(basename(f))
tr   <- tryCatch(read.nexus(f), error = function(e) read.tree(f))
if (inherits(tr, "multiPhylo")) tr <- tr[[1]]
# 2. MATCH
csv_path <- file.path(chrom_dir, paste0(name, ".csv"))
if (!file.exists(csv_path)) next
dat  <- read.csv(csv_path)
dat  <- dat[!is.na(dat$haploid), ]
keep <- intersect(tr$tip.label, dat$species)
if (length(keep) < 3) next
tr_clean <- keep.tip(tr, keep)
tr_clean$edge.length[tr_clean$edge.length <= 0] <- 1e-6
vals <- setNames(dat$haploid[match(keep, dat$species)], keep)
# 3. PREP MAP
obj <- contMap(tr_clean, vals, plot = FALSE, res = 500)
obj <- setMap(obj, viridis(1000, direction = -1))
# 4. RENDER
my_lwd <- max(1.5, 600 / length(keep))
message(paste("Rendering:", name))
png(filename = paste0(name, ".png"), width = 10, height = 10, units = "in", res = out_res)
# FIX: Give the legend 15% of vertical space instead of 10%
layout(matrix(c(1, 2), nrow = 2), heights = c(0.85, 0.15))
# PLOT TREE
par(mar = c(0, 0, 0, 0))
plot(obj, type = "fan", lwd = my_lwd, outline = FALSE, ftype = "off", legend = FALSE)
# PLOT LEGEND
# FIX: Set margins to 0 so we use the full 15% strip we allocated
par(mar = c(0, 0, 0, 0))
plot(0, type = "n", axes = FALSE, xlim = c(0, 1), ylim = c(0, 1), xlab = "", ylab = "")
# FIX: y=0.8 lifts the bar up, leaving room below for the text
add.color.bar(leg = 0.5,
cols = obj$cols,
title = "Haploid Number",
lims = obj$lims,
digits = 1,
prompt = FALSE,
x = 0.25,
y = 0.8,
lwd = 20,
fsize = 1.2,
subtitle = "")
dev.off()
}
